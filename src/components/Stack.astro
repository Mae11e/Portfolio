---
const stack = {
  mastered: ['Python', 'SQL', 'C++'],
  used: ['Airflow', 'Pandas', 'Django', 'Jupyter', 'GitHub', 'DAX', 'Power BI', 'Semantic Models', 'MS Fabric', 'Azure', 'Excel'],
  learning: ['PySpark', 'Spark', 'Databricks', 'Machine Learning'],
};
---
<section id="stack" class="stack">
  <h2 class="section-title">Stack</h2>

  <div class="tier">
    <h3>Mastered</h3>
    <div class="tags">
      {stack.mastered.map((tech) => <span>{tech}</span>)}
    </div>
  </div>

  <div class="tier">
    <h3>Used in projects</h3>
    <div class="tags">
      {stack.used.map((tech) => <span>{tech}</span>)}
    </div>
  </div>

  <div class="tier">
    <h3>Learning</h3>
    <div class="tags">
      {stack.learning.map((tech) => <span>{tech}</span>)}
    </div>
  </div>
</section>

<style>
  .stack {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }
  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    color: var(--ink);
    margin-bottom: 2rem;
  }
  .tier {
    margin-bottom: 2rem;
  }
  .tier h3 {
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tags span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    background: var(--accent-light);
    color: var(--ink);
    padding: 5px 12px;
    border-radius: 6px;
  }
</style>
